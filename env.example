# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/dbname"

# NextAuth
NEXTAUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# SMTP — used for daily sales summary (Gmail: use an App Password if 2FA is on)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
# Set to "false" if you use port 587 with STARTTLS
SMTP_SECURE="true"
SMTP_USER="your-address@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Your App <your-address@gmail.com>"

# Secret for GET /api/cron/daily-sales-summary (Authorization: Bearer <CRON_SECRET>)
# On Vercel, the cron job in vercel.json calls this URL; set the same value in project env.
CRON_SECRET="long-random-string"
